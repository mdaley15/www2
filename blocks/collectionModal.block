<!-- Session modal -->
<div id="collectionModal" class="modal" role="dialog" aria-labelledby="collectionModalLabel">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title" id="collectionModalLabel" tabindex="0">Notice at Collection</h3>
            <button type="button" class="customClose" aria-label="Close">&times;</button>
        </div>
        <div class="modal-body">
            <p>We collect personal information you provide here for the purpose of creating your account, processing orders, and delivering personalized products. We do not sell or share your personal information as defined under the California Privacy Rights Act (CPRA). Information is retained only as long as necessary to fulfill these purposes or as required by law.</p>
            <p><a href="https://inter-state.com/privacy" target="_blank">Privacy Policy</a></p>
        </div>
    </div>
</div>

<style>
/* Notice At Collection */
#collectionModal {
    display: none;
    padding: 20px!important;
    bottom: 0 !important;
    top: unset !important;
    width: 100%;
    overflow-y: hidden;
    overflow-x: visible;
    z-index: 99999!important;
    background: transparent!important;
    box-shadow: none;
    
    .modal-content {
        position: relative;
        border-radius: 5px;
        border: 0;
        width: 100%;
        height: fit-content;
        background-color: white;
        padding: 0;
        box-shadow: 10px 10px 0 #344d87, 0 0 10px rgba(0, 0, 0, .5) !important;
        bottom: -50px;
        opacity: 0;
        transition: all .3s ease-in-out;
        
        .modal-header {
            padding: 15px 25px;
            display: flex;
            justify-content: space-between;
            border-bottom: 1px solid #e5e5e5;

            .modal-title {
                font-family: oswald;
                font-weight: 600;
                font-size: 30px;
                margin: 0;
                color: #344d87;
                line-height: 1;
                padding-top: 3px;
                outline: 0;
            }
            button.customClose {
                background: transparent;
                border: 0;
                outline: 0;
                color: #dd6a14;
                padding: 0;
                font-size: 30px;
                line-height: 1;
                transition: all .3s ease-in-out;

                &:hover,
                &:focus {
                    color: #344d87;
                }
            }
        }
        .modal-body {
            padding: 15px 25px;

            p:last-child {
                margin: 0!important;
            }
            a {
                color: #344d87 !important;
                padding-bottom: .05em;
                border-bottom-width: 1px !important;
                border-bottom-style: solid !important;
                border-bottom-color: transparent !important;
                transition: all .3s ease-in-out;

                &:hover,
                &:focus {
                    border-bottom-color: #dd6a14 !important;
                }
            }
        }
        &.open {
            bottom: 0 !important;
            opacity: 1!important;
        }
    }
    &.open {
        display: block;
    }
    @media only screen and (max-width: 600px) {
        padding: 15px!important;

        .modal-header {
            padding: 10px 15px!important;
        }
        .modal-title {
            font-size: 20px!important;
        }
        button.customClose {
            font-size: 20px!important;
        }
        .modal-body {
            padding: 10px 15px 12px!important;

            p {
                font-size: 14px;
            }
        }
    }
}
.modal-overlay {
    opacity: 0!important;
    pointer-events: none!important;
    display: none!important;
}
</style>

<script type="text/javascript">

    document.addEventListener('DOMContentLoaded', function () {
        var modalElement = document.getElementById('collectionModal');
        var modalContent = modalElement.querySelector('.modal-content');
        var modalTitle = modalElement.querySelector('.modal-title');
        var closeButton = document.querySelector('.customClose');
        var cookieName = 'privacy_modal_schools';

        function showModal() {
            modalElement.classList.add('open');
            modalTitle.focus();
            setTimeout(function () {
                modalContent.classList.add('open');
            }, 100);
        }

        function hideModal() {
            modalContent.classList.remove('open');
            setTimeout(function () {
                modalElement.classList.remove('open');
                modalElement.blur();
            }, 300);
        }

        window.showModal = showModal;

        function getCookie(name) {
            var match = document.cookie.match(new RegExp('(^|; )' + name + '=([^;]*)'));
            return match ? decodeURIComponent(match[2]) : null;
        }

        function setSessionCookie(name, value) {
            // document.cookie = name + '=' + encodeURIComponent(value) + '; path=/';
            document.cookie = name + '=' + encodeURIComponent(value) + '; path=/; Max-Age=0';
        }

        var pathName = window.location.pathname
        if (pathName.includes("/contact-us") || pathName.includes("/request-yearbook-info") || pathName.includes("/request-sample-yearbook")) {
            var shown = getCookie(cookieName);
            console.log('Cookie value:', shown);

            if (!shown) {
                showModal();

                setSessionCookie(cookieName, '1');
            }
        };

        closeButton.addEventListener('click', function () {
            closeButton.blur();
            hideModal();
        });

        document.addEventListener('click', function (event) {
            var target = event.target;

            if (modalContent.contains(target)) {
                return;
            }
            if (target.closest('.privacy-trigger') && modalElement.classList.contains('open')) {
                return;
            }
            if (modalElement.classList.contains('open')) {
                hideModal();
                target.focus();
            }
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape' && modalElement.classList.contains('open')) {
                hideModal();
            }
        });
    });
</script>